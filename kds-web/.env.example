# ============================================
# SUPABASE CONNECTION SETTINGS
# ============================================

# Your direct Supabase project URL
# Format: https://YOURPROJECTID.supabase.co
# Used by: n8n server (runs outside India — not affected by ISP blocks)
# This value is also the fallback for local development
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon (public) key
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon (public)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your Cloudflare Worker proxy URL
# Format: https://api.yourdomain.com
# Used by: All browser-facing React apps (KDS, Manager, Staff POS, Reports)
# Why: Indian ISPs (Jio, Airtel, ACT) blocked *.supabase.co in Feb 2026 under Section 69A
#      This proxy sits on your own domain — ISPs cannot block it without breaking all websites
# How to set this up: Follow cloudflare-worker/README.md step by step (takes ~20 minutes)
# Leave empty for local development — the app falls back to VITE_SUPABASE_URL automatically
VITE_SUPABASE_PROXY_URL=https://api.yourdomain.com

# ============================================
# ERROR TRACKING
# ============================================

# Sentry DSN for production crash reporting
# Found in: Sentry Dashboard → Project → Settings → Client Keys (DSN)
# Leave empty to disable Sentry (e.g. in local development)
VITE_SENTRY_DSN=your-sentry-dsn
