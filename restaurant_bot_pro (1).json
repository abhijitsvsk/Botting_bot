        "jsCode": "const data = this.getWorkflowStaticData('global');\nconst session = data.sessions[$input.item.json.from];\nif (!session.cart || !session.cart.length) return { ...$input.item.json, error: 'EMPTY_CART', error_msg: 'Cart is empty' };\nconst orderId = 'ORD' + Date.now().toString().slice(-6);\nconst total = session.cart.reduce((s, i) => s + (i.price * i.qty), 0);\nconst orderData = { order_id: orderId, table: session.table, items: session.cart, total: total, timestamp: new Date().toISOString(), phone: $input.item.json.from };\nif (!data.orders) data.orders = [];\ndata.orders.push(orderData);\nsession.cart = [];\nreturn { ...$input.item.json, order: orderData };"
