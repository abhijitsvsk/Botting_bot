    {
      "parameters": {
        "jsCode": "const tokens = $input.item.json.text.split(/\\s+/);\nconst items = [];\nfor (let i = 0; i < tokens.length; i++) {\n  if (/^[A-Z]+\\d+$/.test(tokens[i])) {\n    let qty = 1;\n    if (i + 1 < tokens.length && /^\\d+$/.test(tokens[i + 1])) { qty = parseInt(tokens[i + 1]); i++; }\n    if (qty < 1 || qty > 20) return { ...$input.item.json, error: 'INVALID_QTY', error_msg: 'Qty must be 1-20' };\n    items.push({ code: tokens[i], qty });\n  }\n}\nif (!items.length) return { ...$input.item.json, error: 'NO_ITEMS', error_msg: 'No codes found. Use: B1 2' };\nreturn { ...$input.item.json, parsed_items: items };"
      },
