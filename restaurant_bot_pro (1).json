    {
      "parameters": {
        "jsCode": "const raw = ($input.item.json.raw_text || '').toUpperCase();\nconst clean = raw.replace(/[^A-Z0-9\\s]/g, ' ').replace(/\\s+/g, ' ').trim();\nconst interactive = $input.item.json.button_id || '';\nreturn { ...($input.item.json), text: clean, action: interactive.toUpperCase() };"
      },
      "id": "normalize_input",
      "name": "🔄 Normalize Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 400]
    },
    {
      "parameters": {
        "jsCode": "const data = this.getWorkflowStaticData('global');\nconst phone = $input.item.json.from;\nconst now = Date.now();\nif (!data.sessions) data.sessions = {};\nif (!data.sessions[phone]) data.sessions[phone] = { table: null, cart: [], last_seen: now };\nconst session = data.sessions[phone];\nconst expired = (now - session.last_seen) > 900000;\nif (expired) { session.table = null; session.cart = []; }\nsession.last_seen = now;\nreturn { ...($input.item.json), session: session };"
      },
      "id": "load_session",
      "name": "💾 Session Manager",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 400]
    },
