    {
      "parameters": {
        "jsCode": "const menuItems = $input.all().slice(1).map(i => i.json);\nconst currentData = $input.item.json;\nconst parsedItems = currentData.parsed_items;\nconst data = this.getWorkflowStaticData('global');\nconst session = data.sessions[currentData.from];\nconst validItems = [];\nconst invalidItems = [];\nfor (const item of parsedItems) {\n  const menuItem = menuItems.find(m => m.Code === item.code);\n  if (menuItem) validItems.push({ code: item.code, name: menuItem.Name, price: parseFloat(menuItem.Price), qty: item.qty });\n  else invalidItems.push(item.code);\n}\nif (invalidItems.length) return { ...currentData, error: 'INVALID_CODES', error_msg: 'Invalid: ' + invalidItems.join(', ') };\nfor (const item of validItems) {\n  const existing = session.cart.find(c => c.code === item.code);\n  if (existing) existing.qty += item.qty;\n  else session.cart.push(item);\n}\nreturn { ...currentData, session: session, added_items: validItems };"
      },
