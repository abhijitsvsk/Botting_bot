        "jsonBody": "={\"messaging_product\":\"whatsapp\",\"to\":\"{{ $json.from }}\",\"type\":\"text\",\"text\":{\"body\":\"🍽️ Welcome!\\n\\nEnter table number (1-200)\\nExample: 5\"}}"
