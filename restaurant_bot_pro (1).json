        "jsCode": "const session = $input.item.json.session;\nif (!session.cart || session.cart.length === 0) return { ...$input.item.json, cart_empty: true, cart_text: '🛒 Cart empty' };\nconst lines = session.cart.map(i => i.qty + 'x ' + i.name + ' - ₹' + (i.price * i.qty).toFixed(2));\nconst total = session.cart.reduce((s, i) => s + (i.price * i.qty), 0);\nreturn { ...$input.item.json, cart_empty: false, cart_text: '🛒 Cart (Table ' + session.table + ')\\n\\n' + lines.join('\\n') + '\\n\\n━━━━━━━━\\nTotal: ₹' + total.toFixed(2), cart_total: total };"
      },
