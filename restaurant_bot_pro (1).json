      "id": "ask_table_number",
      "name": "📍 Request Table",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 250]
    },
    {
      "parameters": {
        "jsCode": "const text = $input.item.json.text.trim();\nconst match = text.match(/\\b(T|TABLE)?\\s*(\\d+)\\b/i);\nif (!match) return { ...$input.item.json, error: 'INVALID_TABLE', error_msg: 'Invalid table number' };\nconst tableNum = parseInt(match[2]);\nif (tableNum < 1 || tableNum > 200) return { ...$input.item.json, error: 'TABLE_OUT_RANGE', error_msg: 'Table must be 1-200' };\nconst data = this.getWorkflowStaticData('global');\ndata.sessions[$input.item.json.from].table = tableNum.toString();\nreturn { ...$input.item.json, session: data.sessions[$input.item.json.from] };"
      },
      "id": "parse_table_number",
      "name": "🔢 Parse Table",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 550]
